{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.evocatorzombie": {
            "initial_state": "default",
            "states": {
                "default": {
                    "animations": [ "idle" ],
                    "transitions": [
                        { "walk": "query.modified_move_speed > 0.1" }
                    ]
                },
                "walk": {
                    "animations": [ "walk" ],
                    "transitions": [
                        { "default": "query.modified_move_speed <= 0.1" }
                    ]
                }
            }
        }
    }
}
